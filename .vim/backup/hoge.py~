def prime(num, data):
    count = 0
    for n in range(3, num, 2):
        count += 1
        isprime = True
        for i in range(1, len(data)):
            if data[i] ** 2 > n:
                break
            if n % data[i] == 0:
                isprime = False
                break
        if isprime:
            data.append(n)
        if count % 1000 == 0:print(count)
    return data

