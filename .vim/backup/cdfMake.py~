import csv
import numpy as np
import matplotlib.pyplot as plt
from pylab import *

date=[]
count1=[0]
x=[0]
y=[0]

f=open('time_proto_len.csv', 'rb')
dataReader=csv.reader(f)

for row in dataReader:
    if row[1]=='6':
        date.append(int(row[2]))

l=len(date)
for i in range(1, 1500):
    num=count1[i-1]+date.count(i)
    count1.append(num)
    y.append(float(count1[i-1])/l)
    x.append(i)

axis(0, 1500, 0, 1.2)
plt.plot(x, y)
plt.show()
