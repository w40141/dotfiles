import socket
host = 'ec2-54-178-207-186.ap-northeast-1.compute.amazonaws.com'
port = 3333

clientsock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
clientsock.connect((host,port))
startmsg = clientsock.recv(1024)
print startmsg

while True:
    rcvmsg = clientsock.recv(1024)
    print (rcvmsg)

    siki=rcvmsg.split(' ')
    siki.remove("=")
    siki=''.join(siki)
    ans=str(eval(siki))

    # c_msg = raw_input()
    # clientsock.sendall(c_msg)
    clientsock.sendall(ans)
clientsock.close()
