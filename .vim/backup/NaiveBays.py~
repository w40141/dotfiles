    random.shuffle(data)

    #10-fold クロスバリデーション
    k = 0
    for i in range(10):
        student = data[k:k+priod_data]
        if i == 0:
            teacher = data[priod_data:]
        elif i == 9:
            teacher = data[0:(length_data-priod_data)]
        else:
            teacher == data[0:k]
            teacher == data[k+priod_data:]
        k += priod_data
        print "Time : %d" % (i+1)
        nb.train(teacher)
        print nb

        tp = [1]*7
        fp = [0]*7
        fn = [0]*7
        tn = [1]*7
        fpr = [0]*7
        fnr = [0]*7
        print image_class
        for j in range(priod_data):
            guess = nb.classify(student[j][1:])
            for m in range(7):
                if guess == image_class[m]:
                    if guess == student[j][0]:
                        tp[m] += 1
                    else:
                        fp[m] += 1
                else:
                    if guess == student[j][0]:
                        fn[m] += 1
                    else:
                        tn[m] += 1

                fpr[m] = float(fp[m])/(fp[m]+tn[m])
                fnr[m] = float(fn[m])/(tp[m]+fn[m])

                fpr_list.append(fpr[m])
                fnr_list.append(fnr[m])

        print "FPR average rate : %f" %np.average(fpr_list[i*priod_data:(i+1)*priod_data])
        print "FPR standard devison : %f" %np.std(fpr_list[i*priod_data:(i+1)*priod_data])
        print "FNR average rate : %f" % np.average(fnr_list[i*priod_data:(i+1)*priod_data])
        print "FNR standard devison : %f" % np.std(fnr_list[i*priod_data:(i+1)*priod_data])

    print ("")
    print "ALL average"
    print "FPR average rate : %f" % np.average(fpr_list)
    print "FPR standard devison : %f" % np.std(fpr_list)
    print "FNR average rate : %f" % np.average(fnr_list)
