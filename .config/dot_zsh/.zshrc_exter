# dircolors
# https://github.com/seebi/dircolors-solarized
if [[ -d $ZDOTDIR/extra_git/dircolors && -x /usr/local/opt/coreutils/libexec/gnubin/dircolors ]]; then
    eval $(gdircolors $ZDOTDIR/extra_git/dircolors/dircolors.256dark)
    zstyle ':completion:*:default' list-colors ${(s.:.)LS_COLORS}
else
    export LS_COLORS='di=36:ln=35:so=32:pi=33:ex=31:bd=46;34:cd=43;34:su=41;30:sg=46;30:tw=42;30:ow=43;30'
    zstyle ':completion:*:default' list-colors ${(s.:.)LS_COLORS}
fi

# zsh-syntax-highlighting
# https://github.com/zsh-users/zsh-syntax-highlighting
if [ -f $ZDOTDIR/extra_git/zsh-syntax/zsh-syntax-highlighting.zsh ]; then
    source $ZDOTDIR/extra_git/zsh-syntax/zsh-syntax-highlighting.zsh
fi

# zsh-history-substring-search
# https://github.com/zsh-users/zsh-history-substring-search
#			   ./extra_git/zsh-history-substring/zsh-history-substring-search.zsh
if [ -f $ZDOTDIR/extra_git/zsh-history-substring/zsh-history-substring-search.zsh ]; then
    . $ZDOTDIR/extra_git/zsh-history-substring/zsh-history-substring-search.zsh

    # bind P and N for EMACS mode
    bindkey -M emacs '^P' history-substring-search-up
    bindkey -M emacs '^N' history-substring-search-down
fi

# go setting
if [ -x "`which go`" ]; then
	export GOPATH=$HOME/.go
    export PATH=$PATH:$GOPATH/bin
fi

